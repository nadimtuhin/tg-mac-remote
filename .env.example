# ============================================================================
# REQUIRED ENVIRONMENT VARIABLES
# ============================================================================

# Telegram Bot Token (REQUIRED)
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Allowed User IDs (REQUIRED)
# Comma-separated list of Telegram user IDs allowed to control the bot
# Get your user ID from @userinfobot on Telegram
ALLOWED_USER_IDS=123456789,987654321

# ============================================================================
# OPTIONAL ENVIRONMENT VARIABLES
# ============================================================================

# Logging Level (optional, default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# Enabled Plugins (optional)
# Comma-separated list of plugins to load
# Available: terminal, activity, unix, daemon, brew, clipboard, files, system, notifications, apps, screenshot, git, docker, shortcuts, cron, tunnel, opencode, webcam
ENABLED_PLUGINS=terminal,activity,unix,daemon,files

# OpenCode Model (optional)
# AI model for /code command
OPENCODE_MODEL=zai-coding-plan/glm-4.7

# Anthropic API Key (optional)
# Required for OpenCode features if using Anthropic models
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Auto-update (optional)
# Enable automatic self-updates (default: false)
AUTO_UPDATE=false
